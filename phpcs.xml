<?xml version="1.0"?>
<ruleset name="Vibrisse Core">
    <description>WordPress Coding Standards pour Vibrisse Core</description>

    <!-- Dossiers à analyser -->
    <file>inc/</file>
    <file>blocks/</file>
    <file>functions.php</file>

    <!-- Exclusions -->
    <exclude-pattern>experimental/</exclude-pattern>
    <exclude-pattern>vendor/</exclude-pattern>
    <exclude-pattern>node_modules/</exclude-pattern>

    <!-- Standards appliqués -->
    <rule ref="WordPress">
        <!-- Autorise les short ternary -->
        <exclude name="WordPress.PHP.DisallowShortTernary"/>
    </rule>
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array" value="vibrisse-core"/>
        </properties>
    </rule>

    <!-- PHP minimum 8.1 -->
    <config name="minimum_supported_wp_version" value="6.4"/>
    <config name="testVersion" value="8.1-"/>
</ruleset>
