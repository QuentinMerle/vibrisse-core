# Variables d'environnement — vibrisse-core
# Copier ce fichier en .env et adapter les valeurs.
# Ne jamais commiter .env (déjà dans .gitignore).

# ─────────────────────────────────────────
# Vite / Build
# ─────────────────────────────────────────

# URL du site WordPress en développement local
# Utilisée par Vite pour le proxy HMR et les rewrites d'assets.
VITE_DEV_URL=https://vibrisse-local.test

# Port du serveur Vite (optionnel, défaut: 5173)
# VITE_PORT=5173

# ─────────────────────────────────────────
# Environnement WordPress
# ─────────────────────────────────────────
# Note : les variables WordPress (DB, DEBUG, etc.) se configurent
# dans wp-config-local.php (voir pattern ci-dessous), pas ici.
# Ce fichier .env est exclusivement pour les outils Node.js (Vite, scripts).

# ─────────────────────────────────────────
# Pattern recommandé pour wp-config.php
# ─────────────────────────────────────────
# Dans wp-config.php (commité), ajouter avant "That's all, stop editing!":
#
#   // Charge la config locale si elle existe (non commitée).
#   if ( file_exists( dirname( __FILE__ ) . '/wp-config-local.php' ) ) {
#       require_once dirname( __FILE__ ) . '/wp-config-local.php';
#   }
#
# wp-config-local.php (non commité, dans .gitignore) :
#
#   define( 'WP_DEBUG', true );
#   define( 'WP_DEBUG_LOG', true );
#   define( 'WP_DEBUG_DISPLAY', false );
#   define( 'WP_ENVIRONMENT_TYPE', 'local' ); // local | staging | production
#
# Utilisation dans le thème pour du comportement conditionnel :
#
#   if ( 'production' !== wp_get_environment_type() ) {
#       // Code de debug uniquement en local/staging
#   }
