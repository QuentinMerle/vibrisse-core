{
  "name": "vibrisse-core",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint src/js && stylelint src/css",
    "lint:fix": "eslint src/js --fix && stylelint src/css --fix",
    "predeploy": "npm run build && npm run lint && wp vibrisse predeploy",
    "design:import": "node scripts/design-import.js",
    "design:import:dry": "node scripts/design-import.js --dry-run",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/js/**/*.js": ["eslint --fix"],
    "src/css/**/*.css": ["stylelint --fix"]
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0"
  }
}
